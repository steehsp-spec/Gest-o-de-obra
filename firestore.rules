rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "alessandro.aerengenharia2@gmail.com" ||
        request.auth.token.email == "tiiaaoo97@gmail.com" ||
        request.auth.token.email == "steeh.sp@gmail.com" ||
        request.auth.uid == "KGOOZYT9MXZDfo4dmvcem7pvAEo2" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador')
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return hasRequiredFields(['id', 'uid', 'name', 'email', 'role', 'status']) &&
             data.id is string && data.id.size() > 0 &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 5 &&
             data.role in ['administrador', 'engenheiro', 'encarregado', 'financeiro', 'cliente'] &&
             data.status in ['ativo', 'inativo'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'engenheiro');
    }

    match /projectTemplates/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pendencies/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /activities/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /scheduleItems/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /transactions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'financeiro');
    }

    match /settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
